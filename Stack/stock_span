def stock_span(numbers):
  result=[]
  stack=[]
  for i in range(len(numbers)):
    while len(stack)>0 and numbers[stack[-1]]<=numbers[i]:
      stack.pop()
    if len(stack)==0:
      result.append(i+1)
    else:
      result.append(i-stack[-1])
    stack.append(i)
  return result
print(stock_span([100,80,60,70]))